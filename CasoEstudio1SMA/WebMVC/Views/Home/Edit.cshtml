@model EditUserStoryViewModel

@{
    ViewData["Title"] = "Editar Historia";
}

<h2 class="mb-3">Editar Historia</h2>

<form asp-action="Edit" method="post" class="card p-3 shadow-sm">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-2">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" maxlength="120" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="4" maxlength="500"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="UserId" class="form-label">Usuario</label>
        <select asp-for="UserId" asp-items="Model.Users" class="form-select">
            <option value="">Seleccione un usuario</option>
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="Estado" class="form-label"></label>
        <select asp-for="Estado" class="form-select">
            <option value="Backlog">Backlog</option>
            <option value="To Do">To Do</option>
            <option value="In Progress">In Progress</option>
            <option value="Done">Done</option>
        </select>
        <span asp-validation-for="Estado" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Estimacion" class="form-label"></label>
        <input asp-for="Estimacion" class="form-control" type="number" min="2" max="13" />
        <span asp-validation-for="Estimacion" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}