@model BoardViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Sebas Board</h2>
    <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#crearHistoriaModal">
        Crear nuevo
    </button>
</div>

<div class="modal fade" id="crearHistoriaModal" tabindex="-1" aria-labelledby="crearHistoriaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearHistoriaModalLabel">Crear User Story</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label asp-for="CreateStory.Titulo" class="form-label">Titulo</label>
                        <input asp-for="CreateStory.Titulo" class="form-control" maxlength="120" />
                        <span asp-validation-for="CreateStory.Titulo" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="CreateStory.Descripcion" class="form-label">Descripcion</label>
                        <textarea asp-for="CreateStory.Descripcion" class="form-control" rows="3" maxlength="500"></textarea>
                        <span asp-validation-for="CreateStory.Descripcion" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="CreateStory.UserId" class="form-label">Usuario</label>
                        <select asp-for="CreateStory.UserId" asp-items="Model.CreateStory.Users" class="form-select">
                            <option value="">Seleccione un usuario</option>
                        </select>
                        <span asp-validation-for="CreateStory.UserId" class="text-danger"></span>
                    </div>
                    <input asp-for="CreateStory.Estado" type="hidden" value="Backlog" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success btn-sm">Crear</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row">
    @await Html.PartialAsync("_Column", new ColumnViewModel { Name = "Backlog", Stories = Model.Backlog })
    @await Html.PartialAsync("_Column", new ColumnViewModel { Name = "To Do", Stories = Model.ToDo })
    @await Html.PartialAsync("_Column", new ColumnViewModel { Name = "In Progress", Stories = Model.InProgress })
    @await Html.PartialAsync("_Column", new ColumnViewModel { Name = "Done", Stories = Model.Done })
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
